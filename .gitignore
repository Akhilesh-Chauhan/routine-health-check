# ====================================================================
# CRITICAL — Browser profiles contain LIVE SSO session cookies.
# These are the equivalent of a logged-in user. NEVER commit them.
# Same applies to v2's symlinks that point at them and any .bak copies.
# ====================================================================
_browser_profile/
_dev_browser_profile/
_umang_browser_profile/
**/_browser_profile
**/_dev_browser_profile
**/_umang_browser_profile
**/_browser_profile.bak*/
**/_dev_browser_profile.bak*/
**/_umang_browser_profile.bak*/

# Run artifacts — failure screenshots, monitor state, master_report.json.
_hc_artifacts/
**/artifacts/

# Generated dashboard (regenerable from master_report.json).
dashboard.html
dashboard_from_*.html

# Claude Code per-user settings — local, not shared.
.claude/settings.local.json
**/.claude/settings.local.json

# Secrets.
.env
.env.*
*.pem
*.key

# Python.
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Editor / OS.
.DS_Store
*.swp
.idea/
.vscode/
